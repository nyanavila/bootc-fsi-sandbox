# File: infrastructure-soe/Containerfile
FROM registry.access.redhat.com/ubi9/ubi:latest

# Install core kernel, bootc, systemd, and observability engines
RUN dnf -y install bootc kernel grub2 systemd NetworkManager curl && \
    dnf clean all && \
    rm -rf /var/cache/dnf

# Establish tracking variables for Artifactory Promotion Contracts
LABEL io.fsi.soe.version="2.6.0" \
      io.fsi.soe.type="Base-SOE" \
      io.fsi.layer.origin="Patching-Team"
