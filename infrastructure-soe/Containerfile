# File: infrastructure-soe/Containerfile
# Change the FROM line from ubi to the official RHEL 9 bootc base
FROM registry.access.redhat.com/rhel9/rhel-bootc:latest

# Run your system utility installations cleanly now
RUN dnf -y install NetworkManager curl && \
    dnf clean all && \
    rm -rf /var/cache/dnf

LABEL io.fsi.soe.version="2.6.0" \
      io.fsi.soe.type="Base-SOE" \
      io.fsi.layer.origin="Patching-Team"
